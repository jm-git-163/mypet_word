# ============================================================
#  낱말 산책 — 비밀 열쇠 보관 파일 (본보기)
# ------------------------------------------------------------
#  쓰는 법
#    1) 이 파일을 복사해서 이름을 ".env" 로 바꿉니다.
#         copy .env.example .env
#    2) 아래 빈칸에 발급받은 열쇠를 붙여 넣습니다.
#    3) 저장하면 끝입니다. 도구들이 알아서 읽어 갑니다.
#
#  ⚠️ 지켜 주세요
#    · ".env" 파일은 깃(git)에 올라가지 않습니다(.gitignore 에 넣어 두었습니다).
#    · 열쇠를 채팅·이메일·캡처에 붙여 넣지 마세요. 노출되면 즉시 재발급하세요.
#    · 이 열쇠들은 "내 컴퓨터에서 자료를 만들 때"만 쓰입니다.
#      만들어진 mp3·이미지 파일만 앱에 들어가고, 열쇠는 앱에 절대 들어가지 않습니다.
#      (앱에 열쇠를 넣으면 누구나 개발자도구로 꺼내 쓸 수 있습니다.)
# ============================================================


# ── 타입캐스트 (한국어 음성) ─────────────────────────
#  https://typecast.ai  →  로그인 →  API 키 발급
#  낱말을 사람 목소리로 읽어 줄 때 씁니다. 한국어 성우가 자연스럽습니다.
TYPECAST_API_KEY=

#  쓸 성우의 voice_id (비워 두면 도구가 한국어 성우 목록을 보여 줍니다)
#    node tools/build-voice-typecast.js --list
TYPECAST_VOICE_ID=

#  말하기 빠르기 (0.5 ~ 2.0). 어르신께는 0.95 정도가 편합니다.
TYPECAST_TEMPO=0.95


# ── 픽사베이 (배경 그림) ─────────────────────────────
#  https://pixabay.com/api/docs/  →  로그인하면 키가 보입니다
#  ※ 픽사베이 API 는 "이미지와 영상"만 지원합니다. 음악·효과음은 API 로 받을 수 없습니다.
#     그래서 이 열쇠는 동네 배경 그림(벚꽃길·개울·단풍 등)을 받는 데 씁니다.
PIXABAY_API_KEY=


# ── 일레븐랩스 (음성, 타입캐스트 대신 쓰고 싶을 때) ──
#  ⚠️ 예전에 채팅으로 보내신 키는 노출되었으니 반드시 폐기하고 새로 발급하세요.
#  ※ 무료 요금제는 한국어 전용 성우를 API 로 쓸 수 없어 억양이 어색합니다.
#     한국어라면 타입캐스트를 권합니다.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
